package main

import (
	"bytes"
	"encoding/json"
	"fmt"
	"net/http"
	"time"

	"github.com/gdamore/tcell/v2"
	"github.com/rivo/tview"
)

type Character struct {
	Name     string `json:"name"`
	HP       int    `json:"hp"`
	MaxHP    int    `json:"max_hp"`
	Level    int    `json:"level"`
	Strength int    `json:"strength"`
	TargetID string `json:"target_id"` // Кто наш враг
}

type GameState struct {
	Players  map[string]Character `json:"players"`
	Messages []Message            `json:"messages"`
}

type Message struct {
	Author string `json:"author"`
	Text   string `json:"text"`
	Time   string `json:"time"`
}

var (
	hero      Character
	app       *tview.Application
	pages     *tview.Pages
	chatView  *tview.TextView
	pList     *tview.TextView
	serverURL = "http://localhost:8080" // Замени на свой URL
	inBattle  bool
)

func networkLoop() {
	for {
		data, _ := json.Marshal(hero)
		resp, err := http.Post(serverURL+"/sync", "application/json", bytes.NewBuffer(data))
		if err == nil {
			var gs GameState
			json.NewDecoder(resp.Body).Decode(&gs)
			resp.Body.Close()

			app.QueueUpdateDraw(func() {
				updateUI(gs)
				// Если сервер назначил нам врага, а мы еще не в экране боя
				if gs.Players[hero.Name].TargetID != "" && !inBattle {
					hero.TargetID = gs.Players[hero.Name].TargetID
					startPvPPhase()
				}
				// Если бой закончился (HP 0 или TargetID пуст)
				if gs.Players[hero.Name].TargetID == "" && inBattle {
					inBattle = false
					pages.SwitchToPage("menu")
				}
                hero.HP = gs.Players[hero.Name].HP
			})
		}
		time.Sleep(1 * time.Second)
	}
}

func updateUI(gs GameState) {
	pList.Clear()
	fmt.Fprintln(pList, "[yellow]ИГРОКИ (Клик для боя):[-]")
	for _, p := range gs.Players {
		if p.Name == hero.Name { continue }
		fmt.Fprintf(pList, "• %s (HP: %d)\n", p.Name, p.HP)
	}
	chatView.Clear()
	for _, m := range gs.Messages {
		fmt.Fprintf(chatView, "[gray]%s[-] [blue]%s:[-] %s\n", m.Time, m.Author, m.Text)
	}
}

func startPvPPhase() {
	inBattle = true
	var attack, defend string

	form := tview.NewForm().
		AddDropDown("Атака", []string{"head", "torso", "legs"}, 0, func(o string, i int) { attack = o }).
		AddDropDown("Защита", []string{"head", "torso", "legs"}, 0, func(o string, i int) { defend = o }).
		AddButton("Ударить!", func() {
			sendMove(attack, defend)
		})
	
	form.SetBorder(true).SetTitle(fmt.Sprintf(" БОЙ ПРОТИВ %s ", hero.TargetID))
	pages.AddPage("pvp", form, true, true)
}

func sendMove(atk, def string) {
	moveData := map[string]interface{}{
		"player_name": hero.Name,
		"move": map[string]string{"attack": atk, "defend": def},
	}
	b, _ := json.Marshal(moveData)
	go http.Post(serverURL+"/move", "application/json", bytes.NewBuffer(b))
	
	// Показываем заглушку ожидания
	wait := tview.NewModal().SetText("Ожидание хода противника...")
	pages.AddPage("wait", wait, true, true)
}

// --- Остальной код (Main, showMenu, и т.д.) идентичен твоему, с заменой URL ---

func main() {
	app = tview.NewApplication()
	pages = tview.NewPages()
	
	regForm := tview.NewForm()
	regForm.AddInputField("Имя", "", 20, nil, nil).AddButton("Войти", func() {
		hero.Name = regForm.GetFormItem(0).(*tview.InputField).GetText()
		hero.HP, hero.MaxHP, hero.Strength = 100, 100, 15
		showMenu()
		pages.SwitchToPage("menu")
	})
	
	pages.AddPage("init", regForm, true, true)
	go networkLoop()
	app.SetRoot(pages, true).Run()
}

func showMenu() {
	list := tview.NewList().
		AddItem("Вызвать на бой", "Введите имя игрока", '1', func() {
			// Упрощенно: вызываем первого встречного для теста или через ввод
			hero.TargetID = "EnemyName" // В реале тут нужен ввод имени
		}).
		AddItem("Выход", "", 'q', func() { app.Stop() })

	chatView = tview.NewTextView().SetDynamicColors(true)
	chatView.SetBorder(true).SetTitle(" ЧАТ ")
	pList = tview.NewTextView().SetDynamicColors(true).SetBorder(true)

	flex := tview.NewFlex().
		AddItem(list, 20, 1, true).
		AddItem(chatView, 0, 2, false).
		AddItem(pList, 25, 1, false)

	pages.AddPage("menu", flex, true, true)
}
